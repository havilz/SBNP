generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  roman        String
  displayOrder Int       @default(0)
  stations     Station[]

  @@index([displayOrder])
}

model Station {
  id          String   @id
  name        String
  categoryId  Int
  latitude    Float
  longitude   Float
  powerSource String?
  yearBuilt   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reports     Report[]
  category    Category @relation(fields: [categoryId], references: [id])

  @@index([name])
  @@index([categoryId])
}

model Report {
  id               Int         @id @default(autoincrement())
  stationId        String
  reportedAt       DateTime
  conditionPercent Int?
  issueStatus      IssueStatus @default(UNKNOWN)
  issueDuration    Int?
  issueCause       String?
  note             String?
  createdAt        DateTime    @default(now())
  station          Station     @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId])
  @@index([reportedAt])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

enum IssueStatus {
  NIHIL
  PADAM
  RUSAK_RINGAN
  RUSAK_BERAT
  UNKNOWN
}
